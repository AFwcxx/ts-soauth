{
  "name": "ts-soauth",
  "version": "1.0.0",
  "description": "Libsodium security framework for typescript",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build:types": "tsc --project tsconfig.build.json",
    "build:bundle": "tsc",
    "build": "npm run build:types && npm run build:bundle",
    "publish": "npm run build && npm pack",
    "test:host": "npm run build && node ./dist/test/host",
    "test:human": "http-server -o /browser-test",
    "test:machine": "npm run build && node ./dist/test/machine"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AFwcxx/ts-soauth.git"
  },
