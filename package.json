  "bugs": {
    "url": "https://github.com/AFwcxx/ts-soauth/issues"
  },
  "homepage": "https://github.com/AFwcxx/ts-soauth#readme",
  "dependencies": {
    "libsodium-wrappers": "0.7.16",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/libsodium-wrappers": "^0.7.14",
    "@types/node": "^25.5.2",
    "cors": "2.8.6",
    "express": "5.2.1",
    "http-server": "14.1.1",
    "typescript": "6.0.2"
  }
